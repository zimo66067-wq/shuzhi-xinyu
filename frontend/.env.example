# ============================================
# 数智心屿 · 前端环境变量示例
# 使用方法：
#   1. 复制本文件为 .env：  cp .env.example .env
#   2. 修改下面的值
#   3. .env 已在 .gitignore，不会被提交
#
# Vite 规则：只有 VITE_ 前缀的变量会被注入前端
# ============================================

# ---- 家长密码 ----
# 推荐：4-8 位数字或字母，由家长自己设置
# 默认（未配置时）：1234
VITE_PARENT_PASSWORD=1234

# ---- 后端 API 地址（部署时使用） ----
# 开发环境用 vite proxy 时留空即可（请求会走相对路径）
# 生产环境部署到云上时填写真实 URL，例如 https://api.xinyu.example.com
# VITE_API_BASE=
