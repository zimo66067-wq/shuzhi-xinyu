# ============================================
# 数智心屿 · 后端环境变量示例
# 使用方法：
#   1. 复制本文件为 .env：  cp .env.example .env
#   2. 把下面每个 = 后面的占位填成你自己的真实值
#   3. 切勿提交 .env 到 git（已在 .gitignore）
# ============================================

# ---- DeepSeek（必填，对话/评分/报告主模型） ----
# 申请地址：https://platform.deepseek.com
DEEPSEEK_API_KEY=sk-你的DeepSeek密钥

# ---- 腾讯云（必填，语音合成 TTS + 语音识别 STT） ----
# 申请地址：https://console.cloud.tencent.com/cam/capi
# 注意：必须是「主账号」密钥，子账号会报 AuthFailure
TENCENT_SECRET_ID=AKID你的SecretId
TENCENT_SECRET_KEY=你的SecretKey

# ---- 家长鉴权（必填，生产部署务必改） ----
# 家长后台访问密码。建议 ≥ 8 位字母数字组合。
PARENT_PASSWORD=请改成强密码
# 签名密钥（生成短期 token 用）。建议 ≥ 32 字节随机十六进制
# 生成方法：python -c "import secrets; print(secrets.token_hex(32))"
# 不设置则每次重启随机生成（重启后旧 token 失效）
PARENT_SECRET=

# ---- 网络与 CORS（部署相关） ----
# 默认 127.0.0.1 仅本机访问；用 nginx 反代时保持默认
# 局域网/Docker 调试可设 0.0.0.0
FLASK_HOST=127.0.0.1
FLASK_PORT=5000
# DEBUG 模式（绝不可在公网启用！会暴露 Werkzeug 调试器）
FLASK_DEBUG=0

# CORS 允许的前端地址（多个用逗号分隔）
# 默认仅 localhost 开发；部署时改成你的前端域名
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ---- 可选：TTS 音色 ----
# 默认 101005（智莉，温柔幼师风）
# 可选其它：101001(智瑜) / 101008(智琪) / 101011(智凯) / 101016(智乔)
# TTS_VOICE=101005
