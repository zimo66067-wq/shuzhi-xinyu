# 后端环境变量模板
# 复制此文件为 backend/.env 并填写真实值
# backend/.env 不会提交到 Git（已在 .gitignore 中忽略）
#
# 部署到 Render 时：在 Render Dashboard → Environment 中手动填写这些值
# 不要提交真实密钥到 Git！

# ━━━ 必须 ━━━
DEEPSEEK_API_KEY=sk-your-deepseek-api-key
TENCENT_SECRET_ID=AKID-your-tencent-secret-id
TENCENT_SECRET_KEY=your-tencent-secret-key

# ━━━ 推荐修改 ━━━
# 家长端密码（生产环境务必修改默认值！）
PARENT_PASSWORD=请修改为你的强密码
# 家长 token 签名密钥（留空则使用随机生成，重启后旧 token 失效）
PARENT_SECRET=

# ━━━ 安全 ━━━
# CORS 允许的域名（逗号分隔）
# 本地开发:
#   CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Vercel 部署:
#   CORS_ORIGINS=https://shuzhi-xinyu.vercel.app,http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ━━━ 服务器 ━━━
# 监听地址（本地: 127.0.0.1，Docker/Render: 0.0.0.0）
FLASK_HOST=127.0.0.1
FLASK_PORT=5000
# 调试模式（生产环境务必设为 0）
FLASK_DEBUG=0
# Gunicorn 日志级别 (debug / info / warning / error / critical)
GUNICORN_LOG_LEVEL=info
