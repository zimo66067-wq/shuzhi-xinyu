# ============================================
# 数智心屿 · 后端环境变量示例
# 使用方法：
#   1. 复制本文件为 .env：  cp .env.example .env
#   2. 把下面每个 = 后面的占位填成你自己的真实 key
#   3. 切勿提交 .env 到 git（已在 .gitignore）
# ============================================

# ---- DeepSeek（必填，对话/评分/报告主模型） ----
# 申请地址：https://platform.deepseek.com
DEEPSEEK_API_KEY=sk-你的DeepSeek密钥

# ---- 腾讯云（必填，语音合成 TTS + 语音识别 STT） ----
# 申请地址：https://console.cloud.tencent.com/cam/capi
# 注意：必须是「主账号」密钥，子账号会报 AuthFailure
TENCENT_SECRET_ID=AKID你的SecretId
TENCENT_SECRET_KEY=你的SecretKey

# ---- 可选：TTS 音色 ----
# 默认 101005（智莉，温柔幼师风）
# 可选其它：101001(智瑜) / 101008(智琪) / 101011(智凯) / 101016(智乔)
# TTS_VOICE=101005

# ---- 可选：Flask 端口（默认 5000） ----
# FLASK_PORT=5000
